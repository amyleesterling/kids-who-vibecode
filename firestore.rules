rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isValidVote(challengeId) {
      return request.resource.data.keys().hasOnly(['challengeId', 'projectId', 'uid', 'updatedAt'])
        && request.resource.data.challengeId == challengeId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.projectId is string;
    }
    function isValidSubmission() {
      return request.resource.data.keys().hasAll([
        'challengeId', 'childNickname', 'ageBand', 'projectTitle', 'description',
        'repoUrl', 'parentName', 'parentEmail', 'consent', 'publicSharing', 'status'
      ])
        && request.resource.data.childNickname is string
        && request.resource.data.childNickname.size() <= 24
        && request.resource.data.projectTitle is string
        && request.resource.data.projectTitle.size() <= 60
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 280
        && request.resource.data.consent == true
        && request.resource.data.publicSharing == true
        && request.resource.data.status == 'pending';
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if false;
    }

    match /projects/{projectId} {
      allow read: if resource.data.status == 'approved';
      allow write: if false;
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create, update: if signedIn()
        && voteId == request.resource.data.challengeId + '_' + request.auth.uid
        && isValidVote(request.resource.data.challengeId);
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /submissions/{submissionId} {
      allow create: if isValidSubmission();
      allow read, update, delete: if false;
    }
  }
}
